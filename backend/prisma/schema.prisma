generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id    Int     @id @default(autoincrement())
  name  String?
  email String  @unique
}

model Silviu {
  id    Int     @id @default(autoincrement())
  name  String?
  email String  @unique
  age   Int?
  address String?
}